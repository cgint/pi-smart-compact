{
  "name": "pi-smart-compact",
  "version": "0.1.0",
  "description": "Pi extension that replaces built-in compaction with a smarter prompt-driven summary, preserving decisions, blockers, and active work state.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cgint/pi-smart-compact.git"
  },
  "author": "cgint",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "pi-package",
    "pi",
    "coding-agent",
    "extension",
    "compaction",
    "context",
    "summarization"
  ],
  "license": "MIT",
  "files": [
    "index.ts",
    "prompts",
    "src",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.74.0",
    "@earendil-works/pi-coding-agent": ">=0.74.0",
    "@earendil-works/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "precommit": "tsc --noEmit && npm run test && npm audit --audit-level=moderate"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.10",
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "@earendil-works/pi-tui": "^0.80.10",
    "@sinclair/typebox": "^0.34.52",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
